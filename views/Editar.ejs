<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/skeleton/2.0.4/skeleton.min.css">
    <link rel="stylesheet" href="/css/admin.css">
    <title>Editar Platillo</title>
</head>

<body style="background-color: #000; color: white">
    <header>
        <a href="/user/admin">Volver</a>
        <h1>Editar Platillo</h1>
    </header>

    <div class="container" style="margin-top: 50px; padding: 20px;">
        <form action="/user/admin/actualizar/<%= platillo.id %>" method="POST">
            <label for="nombre">Nombre del Platillo</label>
            <input type="text" name="nombre" value="<%= platillo.nombre %>" class="u-full-width" required>

            <label for="descripcion">Descripción</label>
            <textarea name="descripcion" class="u-full-width" required><%= platillo.descripcion %></textarea>

            <label for="precio">Precio</label>
            <textarea name="precio" class="u-full-width" required><%= platillo.precio %></textarea>

            <form action="/user/admin/editar/<%= platillo.id %>" method="GET" style="margin:0;">
                <button type="submit" class="boton-modificar">Modificar</button>
            </form>
        </form>
    </div>
</body>

</html>