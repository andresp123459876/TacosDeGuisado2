<%- include('partials/head') %>
<%- include('partials/header') %>

<main>
    <div id="carrusel" class="ventana-carrusel">
        <div class="contenedor-all-carrusel">
            <div id="carouselExampleControls" class="carousel slide" data-ride="carousel" data-interval="3000">
                <div class="carousel-inner">
                    <% slides.forEach((slide, index) => { %>
                        <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                            <img class="d-block w-100" src="./img/<%= slide.url %>" alt="<%= slide.alt %>">
                        </div>
                    <% }) %>
                </div>
                <a class="carousel-control-prev" href="#carouselExampleControls" role="button" data-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="carousel-control-next" href="#carouselExampleControls" role="button" data-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="sr-only">Next</span>
                </a>
            </div>
        </div>
    </div>

    <div class="descripcion">
        <h1>La mejor comida casera en tu evento</h1>
        <p>"Llevamos el sabor tradicional de Doña Rosa hasta tu mesa"</p>
    </div>

    <div id="foto-de-tacos" class="foto-de-tacos">
        <% tacos.forEach(taco => { %>
            <div class="contenedor-taco">
                <img src="./img/tacos/<%= taco.imagen %>" alt="<%= taco.nombre %>" onclick="mostrarImagen(this)" style="cursor: zoom-in;">
            </div>
        <% }) %>
    </div>

    <section class="servicios-info">
        <h4>Para Evento</h4>
        <h2>Nuestro Servicio Incluye:</h2>
        <div class="grid-servicios">
            <div class="item-servicio">
                <ion-icon class="icon-servicio-info" name="restaurant-outline"></ion-icon>
                <p>Arroz y Frijoles ilimitados</p>
            </div>
            <div class="item-servicio">
                <ion-icon class="icon-servicio-info" name="flame-outline"></ion-icon>
                <p>Guisados calientes en bufetera</p>
            </div>
            <div class="item-servicio">
                <ion-icon class="icon-servicio-info" name="people-outline"></ion-icon>
                <p>Personal para servir</p>
            </div>
        </div>
    </section>

    <section id="ubicacion" class="ubicacion">
        <div class="container text-center py-5">
            <h2>Nuestra Ubicación</h2>
            <p>Av. Reforma, Colonia Ejidal, 23470 Cabo San Lucas, B.C.S.</p>
            <div class="map-responsive">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3675.259!2d-109.9200374!3d22.9014591!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x86af4b80bd45924f%3A0x4f35a4851d3e1b5c!2zRG_DsWEgUm9zYSBUYWNvcyBkZSBHdWlzYWRvIHkgTcOhcw!5e0!3m2!1ses-419!2smx!4v1712000000000!5m2!1ses-419!2smx" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
            </div>
            <div class="link-mapa">
                <a href="https://www.google.com/maps/place/Do%C3%B1a+Rosa+Tacos+de+Guisado+y+M%C3%A1s/@22.901296,-109.9218506,17z/data=!4m6!3m5!1s0x86af4b80bda5924f:0x4f35a4851d3e1b5c!8m2!3d22.9014591!4d-109.9200374!16s%2Fg%2F11n57djgfp?entry=ttu&g_ep=EgoyMDI2MDMzMS4wIKXMDSoASAFQAw%3D%3D" target="_blank" class="btn btn-outline-primary">
                    <ion-icon name="map-outline"></ion-icon> Abrir en Google Maps
                </a>
            </div>
        </div>
    </section>

    <section id="contacto" class="contacto">
        <div class="contenedor-contacto">
            <h1>Direccion: <p>Av. Reforma, Colonia Ejidal, 23470 Cabo San Lucas, B.C.S.</p></h1>
            <h1>Telefono: <p>+52 624 246 1127<br><br>Solo Mensajes por WhatsApp</p></h1>
            <h1>Horario: <p>Lunes a Sábado de 6:00 AM a 2:30 PM (Domingos cerrado).</p></h1>
        </div>
        <div id="redes-sociales">
            <a target="_blank" href="https://www.facebook.com/..."><ion-icon name="logo-facebook"></ion-icon></a>
            <a target="_blank" href="https://www.instagram.com/..."><ion-icon name="logo-instagram"></ion-icon></a>
        </div>
    </section>
</main>

<div id="tacoModal" class="modal-taco" onclick="cerrarImagen()">
    <span class="cerrar-modal">×</span>
    <img class="modal-contenido" id="imgGrande">
    <div id="caption"></div>
</div>

<%- include('partials/scripts') %>