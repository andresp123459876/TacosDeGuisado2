<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tacos de guisado "Rosa"</title>
    <link rel="stylesheet" href="/css/menuYBebidas.css">
    <link rel="stylesheet" href="img/flecha.png">

    <!-- links para googlefonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Comic+Relief:wght@400;700&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Open+Sans:ital,wght@0,300..800;1,300..800&display=swap"
        rel="stylesheet">

</head>

<body>

    <div class="cabeza">
        <h1><a href="/menu">Menu Guisos</a></h1>
        <div class="header logo">
            <a href="/">
                <img src="./img/TacoDeGuisadoLogo.jpg">
                </img>
            </a>
        </div>
        <h1><a href="/menuBebidas">Menu Bebidas</a></h1>
    </div>
    <div class="contenedor">
        <div class="carta-guisos">
            <h1>Menu de Bebidas</h1>
            <% bebidas.forEach(bebida=> { %>
                <div class="informacion">
                    <h2 class="nombre-producto"><%= bebida.nombre %></h2>
                    <ion-icon class="flecha" name="arrow-forward-outline"></ion-icon>
                    <p class="p"><%= bebida.precio %></p>
                </div>
                <% }) %>
        </div>
        <div class="relleno">
            <h6>¡Buen provecho!</h6>
        </div>
    </div>
</body>

<!-- Modulos para ionic.io (iconos) -->
<script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

</html>